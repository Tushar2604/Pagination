# Server
NODE_ENV=development
PORT=3000

# PostgreSQL connection string used by Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/products_db?schema=public

# Pagination defaults
DEFAULT_PAGE_LIMIT=20
MAX_PAGE_LIMIT=100

# CORS — comma-separated browser origins (production)
# ALLOWED_ORIGINS=https://your-app.vercel.app
# FRONTEND_URL=https://your-app.vercel.app

# Seed (Render pre-deploy / local)
# SEED_COUNT=200000
# SEED_BATCH_SIZE=5000
# FORCE_SEED=false
